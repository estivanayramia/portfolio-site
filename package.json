{
  "name": "portfolio-site",
  "version": "2.0.0",
  "description": "Estivan Ayramia's portfolio site with PWA support",
  "scripts": {
    "build:version": "node tools/stamp-build-version.mjs",
    "build:sw": "node tools/stamp-build-version.mjs",
    "build:facts": "node scripts/generate-site-facts.js",
    "build:chat-grounding": "node scripts/generate-chat-grounding.mjs",
    "build:css": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 npx tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --minify",
    "build:theme": "node scripts/build-theme.cjs",
    "build:js": "esbuild assets/js/site.js --bundle --minify --platform=browser --format=iife --target=es2018 --outfile=assets/js/site.min.js",
    "build:lazy": "esbuild assets/js/lazy-loader.js --minify --outfile=assets/js/lazy-loader.min.js",
    "build:telemetry": "esbuild assets/js/telemetry-core.js --minify --keep-names --platform=browser --format=iife --target=es2018 --outfile=assets/js/telemetry-core.min.js",
    "build:hud": "esbuild assets/js/debugger-hud.js --bundle --minify --platform=browser --format=iife --target=es2018 --outfile=assets/js/debugger-hud.min.js",
    "build:coverflow": "esbuild assets/js/carousel/CoverflowCarousel.js --bundle --minify --outfile=assets/js/carousel/CoverflowCarousel.min.js && esbuild assets/css/carousel/coverflow-luxury.css --minify --outfile=assets/css/carousel/coverflow-luxury.min.css",
    "build:luxury-coverflow": "esbuild assets/js/carousel/luxury-coverflow.js --bundle --minify --platform=browser --format=esm --outfile=assets/js/carousel/luxury-coverflow.min.js && esbuild assets/css/components/luxury-coverflow.css --minify --outfile=assets/css/components/luxury-coverflow.min.css",
    "build:stage": "node tools/stage-assets.mjs",
    "upload:facts": "node scripts/upload-site-facts.mjs",
    "verify:pages": "cross-env PAGES_OUTPUT_DIR=dist node tools/verify-pages-output.mjs",
    "sync:index": "node tools/sync-root-index.mjs",
    "route:smoke": "node scripts/route-smoke.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "anim:sanity": "node scripts/animation-sanity.mjs",
    "anim:jank": "node scripts/animation-sanity.mjs --jank",
    "visual:baseline": "node scripts/visual-regression.mjs baseline",
    "visual:check": "node scripts/visual-regression.mjs check",
    "audit:lighthouse:gate": "node scripts/lighthouse-gate.mjs",
    "build": "npm run build:version && npm run apply:versioning && npm run build:facts && npm run build:chat-grounding && npm run build:css && npm run build:js && npm run build:lazy && npm run build:telemetry && npm run build:hud && npm run build:luxury-coverflow && npm run upload:facts && npm run build:stage && npm run verify:pages && npm run verify:versioning",
    "watch": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 npx tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --watch",
    "start": "wrangler pages dev . --port 5500",
    "setup:hooks": "node tools/install-git-hooks.mjs",
    "prepush:dry": "node .githooks/pre-push.mjs",
    "ship": "npm run build && git add -A && git commit -m \"auto-deploy: build\" || echo 'No changes to commit' && git push",
    "ship:force": "npm run build && git add -A && git commit --allow-empty -m \"deploy: force update\" && git push",
    "dev:chat-worker": "cd worker && npx wrangler dev --config wrangler.chat.toml",
    "dev:debugger-worker": "cd worker && npx wrangler dev --config wrangler.debugger.toml",
    "deploy:chat-worker": "cd worker && npx wrangler deploy --config wrangler.chat.toml",
    "deploy:debugger-worker": "cd worker && npx wrangler deploy --config wrangler.debugger.toml",
    "test:redirects": "node scripts/health-check.mjs",
    "test:facts": "node scripts/test-chat-grounding.mjs",
    "test:dashboard": "node scripts/test-dashboard-features-playwright.cjs",
    "test:contact-form": "node scripts/test-contact-form-playwright.cjs",
    "test:carousel": "playwright test tests/carousel-mobile.spec.js",
    "test:intents": "node tools/test-intents.mjs",
    "check:banned": "node scripts/check-banned-patterns.mjs",
    "apply:versioning": "node tools/apply-versioning.mjs",
    "verify:versioning": "node tools/verify-versioning.mjs",
    "check:cache": "node tools/cache-policy-check.mjs --headers _headers",
    "audit:csp": "node scripts/check-csp.cjs",
    "audit:inline-css": "node tools/audit-inline-css.mjs",
    "audit:css-sync": "node tools/audit-css-sync.mjs",
    "audit:cf-files": "node tools/audit-cf-files.mjs",
    "audit:secrets": "node tools/audit-secrets.mjs",
    "audit:sw-version": "node tools/audit-sw-version.mjs",
    "audit:encoding": "node scripts/audit-encoding.mjs",
    "audit:whispers-assets": "node scripts/verify-whispers-note-assets.mjs",
    "audit": "npm run audit:secrets && npm run audit:cf-files && npm run audit:csp && npm run audit:inline-css && npm run audit:css-sync && npm run audit:sw-version && npm run audit:encoding && npm run audit:whispers-assets",
    "sync:whispers-notes": "node scripts/sync-whispers-late-notes.mjs",
    "memory:update": "node tools/update-agent-memory.mjs",
    "memory:health": "node tools/memory-health.mjs",
    "memory:revive": "node tools/revive-claude.mjs",
    "memory:view": "node -e \"const fs=require('fs');const c=fs.readFileSync('CLAUDE.md','utf-8');const m=c.match(/##\\s§AUTO-UPDATE LOG[\\s\\S]+/);console.log(m?m[0]:'§AUTO-UPDATE LOG not found');\""
  },
  "keywords": [
    "portfolio",
    "pwa",
    "progressive-web-app"
  ],
  "author": "Estivan Ayramia",
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@playwright/test": "^1.58.2",
    "autoprefixer": "^10.4.27",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001781",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "lighthouse": "12.6.1",
    "lightningcss": "^1.32.0",
    "pdfjs-dist": "^5.5.207",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.8",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.1",
    "wrangler": "^4.78.0"
  },
  "main": "postcss.config.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estivanayramia/portfolio-site.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/estivanayramia/portfolio-site/issues"
  },
  "homepage": "https://github.com/estivanayramia/portfolio-site#readme",
  "dependencies": {
    "gsap": "^3.14.2",
    "marked": "^17.0.5"
  }
}
